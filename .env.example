# VITE Health Protocol — Environment Variables Example
# Copy this to .env.local and fill in your values for local development.
# For Vercel, add these variables in the Project Settings > Environment Variables dashboard.

# ── XION Testnet-2 Network ─────────────────────────────────────────
# The public RPC endpoint for XION Testnet-2
NEXT_PUBLIC_XION_RPC_URL=https://rpc.xion-testnet-2.burnt.com:443
# The public REST/API endpoint for XION Testnet-2
NEXT_PUBLIC_XION_REST_URL=https://api.xion-testnet-2.burnt.com
# The Chain ID for the current testnet
NEXT_PUBLIC_XION_CHAIN_ID=xion-testnet-2
# The URL for the Abstraxion authentication application
NEXT_PUBLIC_XION_AUTH_APP_URL=https://auth.testnet.burnt.com
# Gas price for transactions (default 0.001uxion)
NEXT_PUBLIC_XION_GAS_PRICE=0.001uxion

# ── Treasury & Auth ───────────────────────────────────────────────
# The meta-account treasury address created at https://dev.testnet2.burnt.com
# Required for session-based signing if enabled.
NEXT_PUBLIC_XION_TREASURY_ADDRESS=

# ── Contract Addresses ─────────────────────────────────────────────
# These addresses are generated after running the deployment script in contracts/scripts/
NEXT_PUBLIC_XION_ISSUER_REGISTRY=
NEXT_PUBLIC_XION_VACCINATION_RECORD=
NEXT_PUBLIC_XION_MILESTONE_CHECKER=
NEXT_PUBLIC_XION_GRANT_ESCROW=

# ── Feature Flags ──────────────────────────────────────────────────
# Set to 'true' to enable real XION blockchain transactions. 
# If 'false', the app may fall back to mock behavior in some areas.
NEXT_PUBLIC_USE_REAL_XION=false

# ── Authentication (NextAuth) ──────────────────────────────────────
# Generate a secure secret using `openssl rand -base64 32`
NEXTAUTH_SECRET=
# The base URL of your application (e.g. http://localhost:3000 or https://your-app.vercel.app)
NEXTAUTH_URL=http://localhost:3000

# ── SMS Notifications (Twilio) ─────────────────────────────────────
# Your Twilio Account SID from the Twilio Console
TWILIO_ACCOUNT_SID=
# Your Twilio Auth Token from the Twilio Console
TWILIO_AUTH_TOKEN=
# Your Twilio Phone Number (in E.164 format, e.g., +1234567890)
TWILIO_PHONE_NUMBER=

# ── Vercel Deployment ──────────────────────────────────────────────
# Optional: Set to 'true' if deploying on Vercel to enable specific optimizations
VERCEL_DEPLOYMENT=true
