# VITE environment template
# NEXT_PUBLIC_ variables are bundled into the client and are safe to set directly in Vercel.
# Never put secrets (private keys, auth tokens, signing credentials) in NEXT_PUBLIC_ variables.
# Contract address variables will remain empty until contracts are deployed to XION testnet-2.
# If contract addresses are empty, XION sync is disabled gracefully; offline registration and
# vaccination recording remain fully functional.

# --- XION Testnet-2 Configuration -------------------------------------------
# Required for XION sync. Set these in Vercel -> Project Settings -> Environment Variables.
# All NEXT_PUBLIC_ variables are exposed client-side. Do not put secrets here.

NEXT_PUBLIC_XION_RPC_URL=https://rpc.xion-testnet-2.burnt.com:443
NEXT_PUBLIC_XION_REST_URL=https://api.xion-testnet-2.burnt.com
NEXT_PUBLIC_XION_CHAIN_ID=xion-testnet-2

# Contract addresses - verified CosmWasm contracts on XION Testnet-2
# If these are rotated or redeployed, update all values together.
NEXT_PUBLIC_XION_ISSUER_REGISTRY=xion1e7chzwjakmf67g2pytcrkefxehxm26xp2w4v4vj5paeaw9v2zdlsesjqc6
NEXT_PUBLIC_XION_VACCINATION_RECORD=xion1nwvuazzwesxssneed5xsgjxycqnadyknc6svq4kzeluhzwqnn2sspznurv
NEXT_PUBLIC_XION_MILESTONE_CHECKER=xion10fwl9vh9esdut8wl37d8p053hxw62thjg65xk26ejm0unpc767rs0qa0ff
NEXT_PUBLIC_XION_GRANT_ESCROW=xion134x0ffm8xukyr2fqe8qwandw6gmv5makn53ja3yvaqrhhhhl7jdqmnhyj7

# Optional XION UI/Abstraxion settings
NEXT_PUBLIC_USE_REAL_XION=true
NEXT_PUBLIC_XION_GAS_PRICE=0.001uxion
NEXT_PUBLIC_XION_AUTH_APP_URL=https://auth.testnet.burnt.com
NEXT_PUBLIC_XION_TREASURY_ADDRESS=
NEXT_PUBLIC_XION_ENABLE_SERVER_SUBMIT=false

# --- Application -------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# --- XION Server-side Submission (Optional Fallback) -------------------------
# Required only if you want to enable the demo-only server-side signing fallback.
# Never expose the mnemonic to the client (no NEXT_PUBLIC_ prefix).
XION_ENABLE_SERVER_SUBMIT=false
XION_SERVER_MNEMONIC=

# --- SMS (server-only - never use NEXT_PUBLIC_ prefix for these) ------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
